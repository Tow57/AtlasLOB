{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "BUILD_TESTING": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "ATLAS_WARNINGS_AS_ERRORS": "ON",
        "ATLAS_ENABLE_INVARIANTS": "ON"
      }
    },
    {
      "name": "dev-gcc",
      "displayName": "Development with GCC",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "dev-clang",
      "displayName": "Development with Clang",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "asan-ubsan",
      "displayName": "Clang with ASan and UBSan",
      "inherits": "dev-clang",
      "cacheVariables": {
        "ATLAS_ENABLE_ASAN": "ON",
        "ATLAS_ENABLE_UBSAN": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release with GCC",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_COMPILER": "g++",
        "ATLAS_ENABLE_INVARIANTS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev-gcc",
      "configurePreset": "dev-gcc"
    },
    {
      "name": "dev-clang",
      "configurePreset": "dev-clang"
    },
    {
      "name": "asan-ubsan",
      "configurePreset": "asan-ubsan"
    },
    {
      "name": "release",
      "configurePreset": "release"
    }
  ],
  "testPresets": [
    {
      "name": "dev-gcc",
      "configurePreset": "dev-gcc",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-clang",
      "configurePreset": "dev-clang",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "asan-ubsan",
      "configurePreset": "asan-ubsan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
